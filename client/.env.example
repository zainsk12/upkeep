# Austrum — Client environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in any values your environment needs.
# All VITE_* variables are inlined at build time by Vite and are NOT secret —
# do NOT put private keys or secrets here.
#
# Variable validation is enforced in src/utils/env.js.
# Add new required variables there AND document them below.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Configuration ─────────────────────────────────────────────────────────
#
# The client uses relative API URLs (/api/*) which are handled by:
#   • Vite dev server proxy  → vite.config.js  (development)
#   • Reverse-proxy / same-origin deployment   (production)
#
# No VITE_API_URL is required under this setup.
# If you ever need to point the client at an external API host, add:
#
#   VITE_API_URL=https://api.yourdomain.com
#
# …and register it as a REQUIRED var in src/utils/env.js.

# ── Firebase (Phone Authentication for signup) — REQUIRED ─────────────────────
# Firebase Console → Project Settings → General → Your apps → Web app → SDK config.
# These are public web keys (not secrets); security is enforced via Firebase
# Authorized domains + server-side Admin SDK token verification.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# OPTIONAL — Firebase App Check site key (reCAPTCHA v3 key registered for App
# Check in the Firebase console). When set, App Check initializes and attaches a
# token to the phone password-reset verification. Leave unset to skip App Check
# (the flow still works). Pair with FIREBASE_APP_CHECK_ENFORCE=true on the server
# to require it.
# VITE_FIREBASE_APP_CHECK_KEY=your_app_check_recaptcha_v3_site_key

# ── Google reCAPTCHA v3 (booking confirmation) — REQUIRED ─────────────────────
# The SITE key (public). The matching SECRET key goes in server/.env.
# Register at https://www.google.com/recaptcha/admin (add upkeep.austrum.co.in
# and localhost as allowed domains).
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key

# ── Razorpay Checkout (cancellation fee — TEST MODE) — OPTIONAL ────────────────
# Publishable key id only (rzp_test_…) — never the key secret (that stays in
# server/.env). Used as a fallback for the key id the pay endpoint already
# returns, so the app works even without this set.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
