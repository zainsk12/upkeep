# ══════════════════════════════════════════════════════════════════════════════
# Austrum — .gitattributes
# Normalises line endings to LF on commit regardless of OS.
# Resolves the mixed CRLF/LF state found across server/, client/, admin-client/.
# ══════════════════════════════════════════════════════════════════════════════

# Default behaviour: auto-detect text files and normalise to LF
* text=auto eol=lf

# ── JavaScript / JSX ──────────────────────────────────────────────────────────
*.js     text eol=lf
*.jsx    text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf

# ── CSS ───────────────────────────────────────────────────────────────────────
*.css    text eol=lf

# ── HTML ──────────────────────────────────────────────────────────────────────
*.html   text eol=lf

# ── JSON ──────────────────────────────────────────────────────────────────────
*.json   text eol=lf

# ── Markdown / Docs ───────────────────────────────────────────────────────────
*.md     text eol=lf
*.txt    text eol=lf

# ── Config files ──────────────────────────────────────────────────────────────
*.env            text eol=lf
*.env.example    text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf

# ── Binaries — do NOT touch these ─────────────────────────────────────────────
*.jpg    binary
*.jpeg   binary
*.png    binary
*.gif    binary
*.webp   binary
*.ico    binary
*.svg    text eol=lf
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.pdf    binary
*.zip    binary
