# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb://localhost:27017/your_database_name

# ⚠️  REQUIRED. Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The server will refuse to start if this is missing or left as the placeholder.
JWT_SECRET=replace_with_a_64byte_random_hex_string
JWT_EXPIRES_IN=7d

CLIENT_ORIGIN=http://localhost:3000
ADMIN_CLIENT_ORIGIN=http://localhost:3001

# ── OTP Configuration ─────────────────────────────────────────────────────────
# REQUIRED. Controls which SMS backend is used.
# ⚠️  This variable is MANDATORY. Leaving it blank or omitting it will cause
#     the server to throw a hard error on the first OTP request.
#
#   "dev"    → Logs OTP to server console only (local development)
#   "msg91"  → Sends real SMS via MSG91 (recommended for India / DLT-compliant)
#   "twilio" → Sends real SMS via Twilio
#
# There is NO automatic fallback to "dev". Set this explicitly.
OTP_PROVIDER=dev

# ── MSG91 (required when OTP_PROVIDER=msg91) ──────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=YOUR_SENDER_ID
MSG91_TEMPLATE_ID=your_msg91_template_id

# ── Twilio (required when OTP_PROVIDER=twilio) ────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000

# ── Site / Footer Contact Details ─────────────────────────────────────────────
# These values are served via GET /api/config/site and rendered in the footer.
# Update here to change contact details without frontend code changes.
SITE_BUSINESS_NAME=Austrum
SITE_TAGLINE=Nashik's Trusted Home Services
SITE_CITY=Nashik, Maharashtra
SITE_PHONE=+91 98765 43210
SITE_EMAIL=support@austrum.in

# ── Reschedule Lockout Window ─────────────────────────────────────────────────
# Minimum number of hours before an appointment during which rescheduling is
# blocked. This value acts as the environment-level default and is overridden
# by any value persisted in the Settings collection (admin-configurable).
#
# Resolution order:
#   1. Settings collection (admin sets via /api/admin/bookings/reschedule-settings)
#   2. This environment variable
#   3. Hard-coded fallback: 2
#
# Set to 0 to disable the lockout guard entirely.
MIN_HOURS_BEFORE_RESCHEDULE=2

# ── Review Settings ────────────────────────────────────────────────────────────
# Minimum star rating a review must have to be shown publicly.
# This value acts as the environment-level default and is overridden by any
# value persisted in the Settings collection (admin-configurable via dashboard).
#
# Resolution order:
#   1. Settings collection (admin sets via /api/admin/reviews/settings)
#   2. This environment variable
#   3. Hard-coded fallback: 4
#
# Must be an integer between 1 and 5.
REVIEW_THRESHOLD_DEFAULT=4

# ── Booking Field Length Limits ────────────────────────────────────────────────
# Maximum character counts for free-text booking fields.
# These act as the environment-level defaults and are overridden by any values
# persisted in the Settings collection (admin-configurable).
# Frontend can fetch the live limits from GET /api/config/booking-field-limits.
#
# Resolution order per field:
#   1. Settings collection
#   2. These environment variables
#   3. Hard-coded fallbacks shown below
BOOKING_LIMIT_ADDRESS=300
BOOKING_LIMIT_SERVICE_ISSUE=1000
BOOKING_LIMIT_NOTES=500
