# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# ⚠️  REQUIRED. Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The server will refuse to start if this is missing or left as the placeholder.
JWT_SECRET=replace_with_a_64byte_random_hex_string
JWT_EXPIRES_IN=7d

# In production set these to the deployed origins, e.g.:
#   CLIENT_ORIGIN=https://upkeep.austrum.co.in
#   ADMIN_CLIENT_ORIGIN=https://admin.upkeep.austrum.co.in
CLIENT_ORIGIN=http://localhost:3000
ADMIN_CLIENT_ORIGIN=http://localhost:3001

# ── Firebase Admin SDK (REQUIRED — phone auth verification) ───────────────────
# Signup verifies the phone via Firebase Phone Authentication. The client gets a
# Firebase ID token; the server verifies it with these service-account creds.
#
# Setup:
#   Firebase Console → Project Settings → Service accounts → Generate new private key
#   From the downloaded JSON, copy the three values below.
# ⚠️  FIREBASE_PRIVATE_KEY must keep the literal \n escapes and be wrapped in
#     double quotes (the server un-escapes \n at runtime).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your-key...IDAQAB\n-----END PRIVATE KEY-----\n"

# ── Firebase App Check (OPTIONAL — hardens the phone password-reset flow) ──────
# When "true", the server REQUIRES a valid Firebase App Check token on the phone
# branch of POST /api/auth/verify-reset-otp, blocking scripted SMS/abuse. Leave
# unset/"false" until App Check is configured in the Firebase console AND the
# client supplies VITE_FIREBASE_APP_CHECK_KEY (the flow works either way).
# Setup: Firebase Console → App Check → register the web app with reCAPTCHA v3.
FIREBASE_APP_CHECK_ENFORCE=false

# ── Google reCAPTCHA v3 (REQUIRED — booking confirmation protection) ──────────
# The booking "Confirm" action runs reCAPTCHA v3 on the client; the server
# verifies the token here. Register a v3 key at https://www.google.com/recaptcha/admin
# (add upkeep.austrum.co.in and localhost as domains). This is the SECRET key.
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
# Minimum passing score (0.0–1.0). Lower = more lenient. Default 0.5.
RECAPTCHA_MIN_SCORE=0.5

# ── Email / Gmail (REQUIRED — customer notification + password-reset emails) ──
# Used for (1) the worker-assigned booking notification and (2) the Forgot
# Password OTP email (Subject: "UpKeep Password Reset Verification"). The phone
# channel of password reset reuses the Firebase Phone Auth config above — no
# additional env vars are needed for the reset feature.
# Sent from this Gmail account using an APP PASSWORD (not the account password).
# Enable 2FA on the account, then:
#   Google Account → Security → 2-Step Verification → App passwords → create one.
EMAIL_USER=upkeep.austrum@gmail.com
EMAIL_APP_PASSWORD=your_16_char_gmail_app_password
EMAIL_FROM="UpKeep by Austrum <upkeep.austrum@gmail.com>"
#
# FUTURE MIGRATION → custom domain sender (upkeep@austrum.co.in):
#   1. Add SPF/DKIM/DMARC DNS records for austrum.co.in (see DEPLOYMENT notes).
#   2. Either use Gmail "Send mail as" (SMTP relay) or a provider (SES/Resend/
#      Postmark). Then set:
#        EMAIL_FROM="UpKeep by Austrum <upkeep@austrum.co.in>"
#      Keep EMAIL_USER as the authenticated SMTP login until the relay is live.

# ── Customer app URL (used to build email links/logo) ─────────────────────────
# Origin of the customer site. The "Track Booking" button links to
# `${CUSTOMER_APP_URL}/my-bookings` and the email logo defaults to
# `${CUSTOMER_APP_URL}/upkeep_logo.png`. Override EMAIL_LOGO_URL to host the
# logo elsewhere (recommended: a stable CDN URL).
CUSTOMER_APP_URL=https://upkeep.austrum.co.in
# EMAIL_LOGO_URL=https://upkeep.austrum.co.in/upkeep_logo.png

# ── Site / Footer Contact Details ─────────────────────────────────────────────
# These values are served via GET /api/config/site and rendered in the footer /
# Contact Us, and SITE_EMAIL is also shown as the support contact in the
# "Password Changed" notification email. SITE_EMAIL is NOT a sender address —
# all mail is sent from EMAIL_USER above. Update here to change contact details
# without frontend code changes.
SITE_BUSINESS_NAME=Austrum
SITE_TAGLINE=Nashik's Trusted Home Services
SITE_CITY=Nashik, Maharashtra
SITE_PHONE=+91 98765 43210
SITE_EMAIL=support.austrum@gmail.com

# ── Reschedule Lockout Window ─────────────────────────────────────────────────
# Minimum number of hours before an appointment during which rescheduling is
# blocked. This value acts as the environment-level default and is overridden
# by any value persisted in the Settings collection (admin-configurable).
#
# Resolution order:
#   1. Settings collection (admin sets via /api/admin/bookings/reschedule-settings)
#   2. This environment variable
#   3. Hard-coded fallback: 2
#
# Set to 0 to disable the lockout guard entirely.
MIN_HOURS_BEFORE_RESCHEDULE=2

# ── Review Settings ────────────────────────────────────────────────────────────
# Minimum star rating a review must have to be shown publicly.
# This value acts as the environment-level default and is overridden by any
# value persisted in the Settings collection (admin-configurable via dashboard).
#
# Resolution order:
#   1. Settings collection (admin sets via /api/admin/reviews/settings)
#   2. This environment variable
#   3. Hard-coded fallback: 4
#
# Must be an integer between 1 and 5.
REVIEW_THRESHOLD_DEFAULT=4

# ── Booking Field Length Limits ────────────────────────────────────────────────
# Maximum character counts for free-text booking fields.
# These act as the environment-level defaults and are overridden by any values
# persisted in the Settings collection (admin-configurable).
# Frontend can fetch the live limits from GET /api/config/booking-field-limits.
#
# Resolution order per field:
#   1. Settings collection
#   2. These environment variables
#   3. Hard-coded fallbacks shown below
BOOKING_LIMIT_ADDRESS=300
BOOKING_LIMIT_SERVICE_ISSUE=1000
BOOKING_LIMIT_NOTES=500
